// Types
interface Message {
  id: string
  content: string
  sender: "user" | "ai"
  timestamp: Date
  type?: "text" | "suggestion" | "action" | "error"
  suggestions?: string[]
  actions?: ChatAction[]
  metadata?: {
    tokens?: number
    model?: string
    latency?: number
  }
}

interface ChatAction {
  id: string
  label: string
  description: string
  icon: React.ReactNode
  href?: string
  action?: () => void  // Add this line
}

interface ChatSession {
  id: string
  title: string
  messages: Message[]
  createdAt: Date
  updatedAt: Date
}

